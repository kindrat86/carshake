    parts.append('<section style="margin-top:32px">')
    parts.append('<h2>What to include when you contact us</h2>')
    parts.append('<p>Email is the fastest way to reach the CarShake team: <strong>hello@carshake.online</strong>. We answer every question personally and usually within a day. Whether you are evaluating the app for a specific use case, hitting a workflow question, or following up on a feature request, the more context you include in your first email the faster we can help.</p>')
