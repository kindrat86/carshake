#!/usr/bin/env python3
"""
CarShake thin-content enricher (section-dispatch pattern).

Reads /tmp/thin-content-manifest.json under 'carshake.online', and for each
thin page dispatches to a section-specific generator that produces ~350-450
words of topic-specific content. Injects surgically before <footer> (or
fallback markers). Idempotent: skips pages already >= 400 visible words.
"""
import json
import re
from pathlib import Path

ROOT = Path("/Users/sipi/carshake")
MANIFEST = Path("/tmp/thin-content-manifest.json")
BASE = "https://carshake.online"
WORD_FLOOR = 400  # skip pages at or above this

# ---------- helpers ----------

def count_visible_words(html: str) -> int:
    txt = re.sub(r'<script[\s\S]*?</script>', ' ', html, flags=re.I)
    txt = re.sub(r'<style[\s\S]*?</style>', ' ', txt, flags=re.I)
    txt = re.sub(r'<[^>]+>', ' ', txt)
    return len(txt.split())


def section_of(url: str) -> str:
    # strip base + leading slash
    path = url.replace(BASE, "").lstrip("/")
    if not path:
        return "home"
    parts = path.rstrip("/").split("/")
    if len(parts) == 1:
        # could be hub (ends with /) or standalone page (faq, contact)
        return parts[0].replace("/", "")
    return parts[0]


def slug_of(url: str) -> str:
    path = url.replace(BASE, "").lstrip("/").rstrip("/")
    parts = path.split("/")
    return parts[-1] if len(parts) > 1 else parts[0]


def humanize(slug: str) -> str:
    return re.sub(r'[-_]+', ' ', slug).strip().title()


def insert_block(html: str, block: str) -> str:
    """Inject block before <footer>, or fallback markers."""
    markers = [
        '<footer',
        '<!-- BRUNSON TRUST BAR',
        '</main>',
        '</article>',
        '</body>',
    ]
    for m in markers:
        idx = html.find(m)
        if idx != -1:
            return html[:idx] + block + "\n" + html[idx:]
    # last resort
    return html + "\n" + block


# ---------- section generators (string concatenation, NOT f-strings) ----------

