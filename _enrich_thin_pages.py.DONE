    "alternatives-to": gen_alternatives,
    "use-cases": gen_usecase,
    "learn": gen_learn,
    "glossary": gen_glossary,
    "integrations": gen_integration,
    "best": gen_best,
    "vs": gen_vs,
    "faq": gen_faq,
    "how-to": gen_howto,
    "templates": gen_template,
    "free": gen_template,        # same shape: template/guide content
    "pricing-questions": gen_pricing,
    "checklists": gen_checklist,
    "cost-of": gen_cost,
}

# Hubs that get a section-keyed intro
HUB_PATHS = {
    "cost-of",
    "checklists",
    "learn",
    "use-cases",
    "reviews",
}


def dispatch_generator(section, path_str, url, h1, desc):
    """Pick the right generator for a given page."""
    # Hub pages: path is the section root
    path_clean = path_str.replace(ROOT.as_posix(), "").lstrip("/")
    # Detect hub (e.g. cost-of.html, learn/index.html, use-cases/index.html, reviews/index.html)
    if (path_clean in ("cost-of.html", "checklists.html") or
            path_clean in ("learn/index.html", "use-cases/index.html", "reviews/index.html")):
        # map file to hub key
        hub_key = path_clean.replace(".html", "").replace("/index.html", "")
        block = gen_hub_content(hub_key)
        if block:
            return block
    # Special standalone pages
    if path_clean == "contact.html":
        return gen_contact(h1, desc, "contact")
    if path_clean == "faq.html":
        return gen_faq(h1, desc, "faq")
    # reviews hub
    if section == "reviews":
        return gen_reviews(h1, desc, "reviews")
    # Section dispatch
    gen = SECTION_GENERATORS.get(section)
    if gen:
        return gen(h1, desc, slug_of(url))
    return gen_generic(h1, desc, slug_of(url))


# ---------- duplicate twin detection ----------

def find_duplicate_twins():
    """Return list of (index_file, slug_file) pairs where both exist."""
    twins = []
    for idx in ROOT.rglob("index.html"):
        if ".vercel" in str(idx) or "node_modules" in str(idx):
            continue
        slug_html = idx.parent.parent / (idx.parent.name + ".html")
        if slug_html.exists() and slug_html.is_file():
            twins.append((idx, slug_html))
    return twins


def resolve_all_files_for_url(url):
    """Return all on-disk files that Vercel might serve for this URL."""
    path = url.replace(BASE, "").lstrip("/")
    if not path:
        return [ROOT / "index.html"]
    candidates = []
    # /slug/  ->  slug/index.html
    candidates.append(ROOT / path / "index.html")
    # /slug  ->  slug.html  OR  slug/index.html (clean URL)
    candidates.append(ROOT / (path + ".html"))
    # /dir/  ->  dir.html (some generators do this)
    if path.endswith("/"):
        candidates.append(ROOT / (path.rstrip("/") + ".html"))
    return [c for c in candidates if c.exists() and c.is_file()]


# ---------- main ----------

def main():
    data = json.loads(MANIFEST.read_text())
    site = data["carshake.online"]
    thin_pages = site["thin_pages"]

    # Detect duplicate twins up front so we can sync after patching
    twins = find_duplicate_twins()
    twin_slug_to_idx = {}
    for idx_f, slug_f in twins:
        twin_slug_to_idx[slug_f] = idx_f

    stats = {"enriched": 0, "skipped": 0, "failed": 0, "no_block": 0}
    results = []

    for entry in thin_pages:
        url = entry["url"]
        primary_path = Path(entry["path"])
        h1 = entry.get("h1", "")
        desc = entry.get("description", "")

        if not primary_path.exists():
            print("MISSING: " + url + " -> " + str(primary_path))
            stats["failed"] += 1
            continue

        existing = primary_path.read_text(errors="ignore")
        wc_before = count_visible_words(existing)
        if wc_before >= WORD_FLOOR:
            stats["skipped"] += 1
            results.append((url, primary_path, wc_before, wc_before, "skip"))
            continue

        section = section_of(url)
        block = dispatch_generator(section, str(primary_path), url, h1, desc)
        if not block:
            print("NO BLOCK: " + url + " (section=" + section + ")")
            stats["no_block"] += 1
            continue

        # Inject into primary
        enriched = insert_block(existing, block)
        primary_path.write_text(enriched)
        wc_after = count_visible_words(enriched)

        # Sync duplicate twin if present
        twin_synced = False
        if primary_path in twin_slug_to_idx:
            idx_file = twin_slug_to_idx[primary_path]
            # Preserve index.html canonical
            idx_canon = re.search(r'<link rel="canonical" href="([^"]+)"',
                                  idx_file.read_text(errors="ignore"))
            slug_canon = re.search(r'<link rel="canonical" href="([^"]+)"', enriched)
            rich = enriched
            if idx_canon and slug_canon and idx_canon.group(1) != slug_canon.group(1):
                rich = rich.replace(slug_canon.group(1), idx_canon.group(1))
            idx_file.write_text(rich)
            twin_synced = True

        # Also handle case where there are OTHER files Vercel might serve
        served_files = resolve_all_files_for_url(url)
        for sf in served_files:
            if sf == primary_path:
                continue
            if sf in twin_slug_to_idx.values():
                continue  # already handled
            sf_text = sf.read_text(errors="ignore")
            if count_visible_words(sf_text) < WORD_FLOOR:
                # preserve canonical of the served file
                sf_canon = re.search(r'<link rel="canonical" href="([^"]+)"', sf_text)
                rich = enriched
                if sf_canon and slug_canon:
                    rich = rich.replace(slug_canon.group(1), sf_canon.group(1))
                sf.write_text(rich)

        stats["enriched"] += 1
        results.append((url, primary_path, wc_before, wc_after,
                        "twin-synced" if twin_synced else "ok"))

    # Print report
    print("\n" + "=" * 78)
    print("ENRICHMENT REPORT — carshake.online")
    print("=" * 78)
    print("Total thin pages in manifest: " + str(len(thin_pages)))
    print("Enriched: " + str(stats["enriched"]))
    print("Skipped (already >= " + str(WORD_FLOOR) + " words): " + str(stats["skipped"]))
    print("No block generated: " + str(stats["no_block"]))
    print("Failed/missing: " + str(stats["failed"]))
    print()
    print("Per-page word counts (before -> after):")
    print("-" * 78)
    for url, path, wc_b, wc_a, status in sorted(results, key=lambda r: r[2]):
        rel = str(path.relative_to(ROOT)) if path.is_relative_to(ROOT) else str(path)
        flag = "" if wc_a >= 500 else "  <-- UNDER 500"
        print(str(wc_b).rjust(4) + " -> " + str(wc_a).rjust(4) + "  " + status.ljust(12) + "  " + url + flag)
    print("-" * 78)
    under = [r for r in results if r[3] < 500]
    print("Pages still under 500 words: " + str(len(under)))
    for u in under:
        print("  " + u[0] + " (" + str(u[3]) + " words)")


if __name__ == "__main__":
    main()
