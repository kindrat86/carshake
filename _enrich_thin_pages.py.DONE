    parts.append('<li><strong>Guided 8-angle scan in 60 seconds</strong> — walks you through exactly the angles that catch real-world damage.</li>')
    parts.append('<li><strong>Automatic timestamping and geo-location</strong> on every photo, baked into the metadata.</li>')
    parts.append('<strong>Before/after diff</strong> that highlights new damage between any two scans.</li>')
