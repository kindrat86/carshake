def gen_usecase(h1, desc, slug):
    audience = humanize(slug)
    parts = []
    parts.append('<section style="margin-top:32px">')
    parts.append('<h2>Common scenarios for ' + audience.lower() + '</h2>')
    parts.append('<p>' + audience + ' face a specific cluster of damage-risk moments that CarShake is built to document. The pattern is always the same: someone else takes possession of your vehicle, and when you get it back, there is a fresh dent, scratch, or curb rash that was not there before. Without a time-stamped pre-scan, the operator, valet, rental counter, or hotel will almost always deny responsibility — and you eat the cost.</p>')
    parts.append('<ul>')
    parts.append('<li><strong>Handing over the keys:</strong> you scan the car at 8 standard angles in under 60 seconds before you hand the keys over. CarShake time-stamps and geo-locates every photo.</li>')
    parts.append('<li><strong>Getting the car back:</strong> you run the same 8-angle scan. CarShake generates a before/after diff that isolates any new damage.</li>')
    parts.append('<li><strong>The dispute moment:</strong> if a new ding appears, you have a court-admissible record showing the condition right before and right after the handover — the exact window the damage occurred.</li>')
    parts.append('<li><strong>The receipt:</strong> CarShake produces a QR-coded handover receipt the operator can scan and acknowledge at the moment of transfer, which dramatically cuts later denials.</li>')
    parts.append('</ul>')
    parts.append('<h2>Before CarShake vs after</h2>')
    parts.append('<p><strong>Before:</strong> you hand the keys over with a mental note of the car\'s condition. When you find damage later, you have no time-stamped proof of when it happened. The operator says the damage was pre-existing or happened after you left the lot. You have no leverage. You pay the deductible, lose hours on the phone, and walk away frustrated.</p>')
    parts.append('<p><strong>After:</strong> the entire handover takes 60 extra seconds. You walk away with a QR receipt and a time-stamped condition record. If damage shows up, the diff proves it happened during the handover window. Operators who would otherwise stonewall you tend to resolve the claim quickly when confronted with documented evidence. The average valet damage claim runs $2,100 — a 60-second scan is the cheapest insurance you will ever buy.</p>')
    parts.append('<h2>ROI for ' + audience.lower() + '</h2>')
    parts.append('<p>One prevented dispute pays for roughly 14 years of CarShake at the founding price of $2.97/month. For ' + audience.lower() + ' who hand their car to anyone else even a few times a year — airport valet, hotel valet, restaurant valet, rental returns, dealer service, body shop — the math is straightforward. The free tier gives you 3 scans to prove the workflow fits your life before you ever pay anything. Founding spots are limited (73 of 100 remain at the time of writing) and the founding price locks forever.</p>')
    parts.append('</section>')
    return "\n".join(parts)


def gen_learn(h1, desc, slug):
